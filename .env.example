# ─────────────────────────────────────────────────────────────────────
# transcomonitor — Variables d'environnement
# Copier en .env (gitignored) pour le dev local. En prod (shinyapps.io)
# ces variables sont définies dans le dashboard de l'app.
# ─────────────────────────────────────────────────────────────────────

# ── OMS ICD-11 API (OAuth2 client_credentials) ──────────────────────
# Obtenir les credentials depuis https://icd.who.int/icdapi
WHO_CLIENT_ID=
WHO_CLIENT_SECRET=

# ── Mistral LLM (V2 — assistance contextuelle à l'édition) ───────────
MISTRAL_API_KEY=

# ── AWS S3 (persistance MVP : SQLite snapshots + library) ───────────
# Naming AWS standard (boto3 les reconnaît nativement)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=transcomonitor
S3_REGION=eu-west-3
# Optionnel — boto3 dérive l'URL de la région si omis.
# Définir pour buckets non-AWS (OVH, Scaleway, MinIO, …)
S3_ENDPOINT_URL=https://s3.eu-west-3.amazonaws.com

# ── Application ─────────────────────────────────────────────────────
# Mot de passe initial du compte admin créé au premier boot.
# Si vide, un mot de passe aléatoire est généré et logué une fois.
DEFAULT_ADMIN_PASS=

# Clé Fernet 32 bytes base64 pour chiffrer les secrets stockés en DB
# (clés API tierces). Générer avec : python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DB_ENCRYPTION_KEY=

# Surcharge du chemin SQLite (dev local uniquement — en prod auto /tmp sur shinyapps.io)
# TRANSCOMONITOR_DB_PATH=/path/to/local.sqlite

# ── PostgreSQL (V1 — décommenter à la migration) ────────────────────
# DATABASE_URL=postgresql+psycopg://user:pwd@host:5432/dbname?sslmode=require
